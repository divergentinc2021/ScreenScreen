{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/electron",
    "rootDir": "electron",
    "declaration": false,
    "lib": ["ES2022"]
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules"]
}
